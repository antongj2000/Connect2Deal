@model Connect2Deal.ViewModels.Listing
@{
    ViewData["Title"] = "Post a listing";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
        <div class="c2d-card">

            <h3 class="c2d-title">Post a listing</h3>
            <p class="c2d-subtitle">Fill in the details — your item goes live for 10 days.</p>

            <form asp-action="CreateListing" method="post">

                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-semibold"></label>
                    <input asp-for="Title" class="form-control" placeholder="e.g. iPhone 17 Pro Max, 256GB" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="ParentCategory" class="form-label fw-semibold"></label>
                        <select asp-for="ParentCategory" asp-items="Model.ParentCategories"
                                id="parentCategory" class="form-select">
                            <option value="">Choose a category</option>
                        </select>
                        <span asp-validation-for="ParentCategory" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="ChildCategory" class="form-label fw-semibold"></label>
                        <select asp-for="ChildCategory" asp-items="Model.ChildCategories"
                                id="childCategory" class="form-select" disabled>
                            <option value="">Choose a category first</option>
                        </select>
                        <span asp-validation-for="ChildCategory" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Country" class="form-label fw-semibold"></label>
                        <select asp-for="Country" asp-items="Model.Countries"
                                id="country" class="form-select">
                            <option value="">Choose a country</option>
                        </select>
                        <span asp-validation-for="Country" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="City" class="form-label fw-semibold"></label>
                        <select asp-for="City" asp-items="Model.Cities"
                                id="city" class="form-select" disabled>
                            <option value="">Choose a country first</option>
                        </select>
                        <span asp-validation-for="City" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Price" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <input asp-for="Price" class="form-control" placeholder="0.00" />
                        <span class="input-group-text">€</span>
                    </div>
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label fw-semibold"></label>
                    <textarea asp-for="Description" class="form-control" rows="6"
                              placeholder="Condition, age, what's included..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">Publish listing</button>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function chain(parentId, childId, url) {
            const parent = document.getElementById(parentId);
            const child = document.getElementById(childId);

            async function load(parentValue, selectedId = null) {
                child.innerHTML = '<option value="">Choose</option>';

                if (!parentValue) {
                    child.disabled = true;
                    return;
                }

                const response = await fetch(`${url}?parentId=${parentValue}`);
                const items = await response.json();

                items.forEach(item => {
                    const opt = document.createElement('option');
                    opt.value = item.id;
                    opt.textContent = item.name;
                    if (selectedId && item.id == selectedId) opt.selected = true;
                    child.appendChild(opt);
                });

                child.disabled = false;
            }

            parent.addEventListener('change', () => load(parent.value));

            if (parent.value) {
                load(parent.value, child.value);
            }
        }

        chain('parentCategory', 'childCategory', '/Listing/SubCategories');
        chain('country', 'city', '/Listing/Cities');
    </script>
}