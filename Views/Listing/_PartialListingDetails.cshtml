@using System.Text.Json
@model Connect2Deal.Models.Listing

@{
    var cat = Model.Category?.Name ?? "Other";
    var hue = System.Math.Abs(cat.GetHashCode()) % 360;
    var images = Model.ListingImages?.OrderByDescending(i => i.IsPrimary).ToList() ?? new List<Connect2Deal.Models.ListingImage>();
    var hasImages = images.Count > 0;
}

@if (hasImages)
{
    var jsonImages = JsonSerializer.Serialize(images.Select(i => i.ImagePath));

    <!-- DODAT TAČAN ID: id="c2d-main-slider-container" -->
    <div id="c2d-main-slider-container" class="c2d-detail-thumb c2d-slider-container" style="--h:@hue; position: relative; overflow: hidden; height: 350px;">

        <img id="c2d-main-slider-img" src="@images[0].ImagePath" alt="@Model.Title"
     style="width:100%; height:100%; object-fit:cover; border-radius:22px 22px 0 0; cursor: pointer;"
     onclick="
        var fs = document.getElementById('c2d-fs-overlay');
        var container = this.closest('.c2d-slider-container');
        
        // Pokušaj da nađeš strelicu, ako ne postoji (1 slika), podrazumevana vrednost je 0
        var arrow = container ? container.querySelector('.c2d-slider-arrow') : null;
        var current = arrow ? parseInt(arrow.getAttribute('data-current')) : 0;
        
        // Izvlačimo niz slika direktno iz data-images atributa sa overlay-a koji uvek postoji
        var imgs = JSON.parse(fs.getAttribute('data-images'));

        fs.setAttribute('data-current', current);
        fs.querySelector('#c2d-fs-img').src = imgs[current];
        fs.querySelector('#c2d-fs-index').innerText = current + 1;
        fs.style.display = 'flex';
     " />

        <span class="c2d-detail-cat">@cat</span>

        @if (images.Count > 1)
        {
            <div class="c2d-slider-badge" style="position: absolute; top: 15px; right: 60px; background: rgba(0,0,0,0.6); color: #fff; padding: 4px 10px; border-radius: 12px; font-size: 14px; font-weight: bold; z-index: 10;">
                <span id="c2d-slider-index">1</span>/@images.Count
            </div>

            <button type="button" class="c2d-slider-arrow"
                    data-images="@jsonImages"
                    data-current="0"
                    onclick="
                                var imgs = JSON.parse(this.getAttribute('data-images'));
                                var current = parseInt(this.getAttribute('data-current'));
                                current = (current - 1 + imgs.length) % imgs.length;
                                this.setAttribute('data-current', current);
                                this.nextElementSibling.setAttribute('data-current', current);
                                var container = this.closest('.c2d-slider-container');
                                container.querySelector('#c2d-main-slider-img').src = imgs[current];
                                container.querySelector('#c2d-slider-index').innerText = current + 1;
                            "
                    style="position: absolute; left: 15px; top: 50%; transform: translateY(-50%); background: rgba(255,255,255,0.8); border: none; width: 40px; height: 40px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 20px; font-weight: bold; box-shadow: 0 2px 5px rgba(0,0,0,0.2); z-index: 10;">
                &#10094;
            </button>

            <button type="button" class="c2d-slider-arrow"
                    data-images="@jsonImages"
                    data-current="0"
                    onclick="
                                var imgs = JSON.parse(this.getAttribute('data-images'));
                                var current = parseInt(this.getAttribute('data-current'));
                                current = (current + 1) % imgs.length;
                                this.setAttribute('data-current', current);
                                this.previousElementSibling.setAttribute('data-current', current);
                                var container = this.closest('.c2d-slider-container');
                                container.querySelector('#c2d-main-slider-img').src = imgs[current];
                                container.querySelector('#c2d-slider-index').innerText = current + 1;
                            "
                    style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%); background: rgba(255,255,255,0.8); border: none; width: 40px; height: 40px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 20px; font-weight: bold; box-shadow: 0 2px 5px rgba(0,0,0,0.2); z-index: 10;">
                &#10095;
            </button>
        }
    </div>

    <!-- FULLSCREEN OVERLAY SADA SA SIGURNIM PROVJERAMA UNUTAR ONCLICK-A -->
    <div id="c2d-fs-overlay" data-images="@jsonImages" data-current="0" style="display: none; position: fixed; z-index: 99999; left: 0; top: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.95); align-items: center; justify-content: center; backdrop-filter: blur(8px);">

        <span onclick="this.parentElement.style.display = 'none';" style="position: absolute; top: 20px; right: 25px; color: #fff; font-size: 40px; font-weight: bold; cursor: pointer; z-index: 100000; user-select: none;">&times;</span>

        <div style="position: absolute; top: 25px; left: 50%; transform: translateX(-50%); color: #fff; font-size: 16px; font-weight: bold; background: rgba(255,255,255,0.2); padding: 4px 14px; border-radius: 20px;">
            <span id="c2d-fs-index">1</span>/@images.Count
        </div>

        <img id="c2d-fs-img" src="@images[0].ImagePath" alt="Full view" style="max-width: 95vw; max-height: 90vh; object-fit: contain; user-select: none;" />

        @if (images.Count > 1)
        {
            <button type="button" onclick="
                    var ov=this.parentElement;
                    var imgs=JSON.parse(ov.getAttribute('data-images'));
                    var current=parseInt(ov.getAttribute('data-current'));
                    current=(current - 1 + imgs.length) % imgs.length;
                    ov.setAttribute('data-current', current);
                    ov.querySelector('#c2d-fs-img').src=imgs[current];
                    ov.querySelector('#c2d-fs-index').innerText=current + 1;
                    var mainContainer=document.getElementById('c2d-main-slider-container');
                    if (mainContainer) {
                    var arrows=mainContainer.querySelectorAll('.c2d-slider-arrow');
                    arrows.forEach(a=>
                a.setAttribute('data-current', current));
                mainContainer.querySelector('#c2d-main-slider-img').src = imgs[current];
                mainContainer.querySelector('#c2d-slider-index').innerText = current + 1;
                }
                " style="position: absolute; left: 20px; top: 50%; transform: translateY(-50%); background: rgba(255,255,255,0.15); color: white; border: none; width: 50px; height: 50px; border-radius: 50%; cursor: pointer; font-size: 24px; display: flex; align-items: center; justify-content: center;">&#10094;
            </button>

            <button type="button" onclick="
                    var ov=this.parentElement;
                    var imgs=JSON.parse(ov.getAttribute('data-images'));
                    var current=parseInt(ov.getAttribute('data-current'));
                    current=(current + 1) % imgs.length;
                    ov.setAttribute('data-current', current);
                    ov.querySelector('#c2d-fs-img').src=imgs[current];
                    ov.querySelector('#c2d-fs-index').innerText=current + 1;
                    var mainContainer=document.getElementById('c2d-main-slider-container');
                    if (mainContainer) {
                    var arrows=mainContainer.querySelectorAll('.c2d-slider-arrow');
                    arrows.forEach(a=>
                a.setAttribute('data-current', current));
                mainContainer.querySelector('#c2d-main-slider-img').src = imgs[current];
                mainContainer.querySelector('#c2d-slider-index').innerText = current + 1;
                }
                " style="position: absolute; right: 20px; top: 50%; transform: translateY(-50%); background: rgba(255,255,255,0.15); color: white; border: none; width: 50px; height: 50px; border-radius: 50%; cursor: pointer; font-size: 24px; display: flex; align-items: center; justify-content: center;">&#10095;
            </button>
        }
    </div>
}
else
{
    <div class="c2d-detail-thumb" style="--h:@hue">
        <span class="c2d-detail-initial">@cat.Substring(0, 1)</span>
        <span class="c2d-detail-cat">@cat</span>
    </div>
}

<div class="c2d-detail-body">
    <div class="c2d-detail-header">
        <h2 class="c2d-detail-title">@Model.Title</h2>
        <span class="c2d-detail-price">@(Model.Price?.ToString("N0") ?? "0") €</span>
    </div>

    <div class="c2d-detail-meta">
        <span>◍ @(Model.Location?.Name ?? "—")</span>
        <span>·</span>
        <span>Posted @Model.CreatedAt.ToString("dd MMM yyyy")</span>
    </div>

    @if (images.Count > 1)
    {
        <div style="display:flex; gap:8px; margin-top:12px; overflow-x:auto; padding-bottom:4px;">
            @foreach (var img in images)
            {
                <img src="@img.ImagePath" alt="@Model.Title"
                     style="width:80px; height:80px; object-fit:cover; border-radius:10px; cursor:pointer; border:2px solid transparent;"
                     onclick="
                     var mainContainer=document.getElementById('c2d-main-slider-container');
                     if (mainContainer) {
                     mainContainer.querySelector('#c2d-main-slider-img').src=this.src;
                     var index=Array.from(this.parentElement.children).indexOf(this);
                     mainContainer.querySelectorAll('.c2d-slider-arrow').forEach(a=> a.setAttribute('data-current', index));
                mainContainer.querySelector('#c2d-slider-index').innerText = index + 1;
                }
                " />
            }
        </div>
    }

    <hr class="c2d-detail-hr" />

    <div class="c2d-detail-section">
        <h4>Description</h4>
        <p class="c2d-detail-desc">@Model.Description</p>
    </div>

    <hr class="c2d-detail-hr" />

    <div class="c2d-detail-section">
        <h4>Seller</h4>
        <div class="c2d-detail-seller">
            <div class="c2d-detail-avatar">@(Model.User?.Username?.Substring(0, 1).ToUpper() ?? "?")</div>
            <div>
                <div class="c2d-detail-seller-name">@(Model.User?.Username ?? "Unknown")</div>
                <div class="c2d-detail-seller-since">Member since @(Model.User?.CreatedAt.ToString("MMM yyyy"))</div>
            </div>
        </div>
    </div>

    @if (User.Identity != null && User.Identity.IsAuthenticated && Model.User != null)
    {
        <div class="c2d-detail-actions">
            <a href="#" class="c2d-detail-msg" data-soon="true">Message seller</a>
        </div>
    }
</div>